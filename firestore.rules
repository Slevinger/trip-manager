rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MVP: any signed-in user (custom token from this app) can read/write trips.
    // Tighten with request.auth.token.tripId or your own checks before production.
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
    }
  }
}
